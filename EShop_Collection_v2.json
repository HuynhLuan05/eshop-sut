              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "pm.test(\"Message is 'Login successful'\", function () { var jsonData = pm.response.json(); pm.expect(jsonData.message).to.eql('Login successful'); });",
                  "pm.test(\"Token exists and is string\", function () { var jsonData = pm.response.json(); pm.expect(jsonData.token).to.be.a('string').and.not.empty; pm.collectionVariables.set('token', jsonData.token); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
