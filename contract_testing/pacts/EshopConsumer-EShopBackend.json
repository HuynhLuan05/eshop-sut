{
  "consumer": {
    "name": "EshopConsumer"
  },
  "interactions": [
    {
      "description": "a request to add item to cart",
      "providerStates": [
        {
          "name": "cart is empty or ready"
        }
      ],
      "request": {
        "body": {
          "productId": 1,
          "quantity": 2
        },
        "headers": {
          "Authorization": "Bearer mock-token",
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/cart"
      },
      "response": {
        "body": {
          "productId": 1,
          "quantity": 2
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.productId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.quantity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "EShopBackend"
  }
}